## ASYNC PATTERNS

For asynchronous code:

1. USE Tokio for native platforms and wasm-bindgen-futures for WASM
2. IMPLEMENT cancellation through drop semantics
3. PROPAGATE context in async tasks
4. AVOID blocking the main thread, especially in WebAssembly
5. HANDLE backpressure explicitly

ONE SOLUTION ONLY:
```rust
// Async pattern with platform abstraction
#[cfg(target_arch = "wasm32")]
pub async fn load_resource(url: &str) -> Result<Vec<u8>, BrushError> {
    use wasm_bindgen::{JsCast, prelude::*};
    use wasm_bindgen_futures::JsFuture;
    use web_sys::{Request, RequestInit, RequestMode, Response};
    
    let mut opts = RequestInit::new();
    opts.method("GET");
    opts.mode(RequestMode::Cors);
    
    let request = Request::new_with_str_and_init(url, &opts)
        .map_err(|e| BrushError::Config(format!("Request error: {:?}", e)))?;
    
    let window = web_sys::window().unwrap();
    let resp_value = JsFuture::from(window.fetch_with_request(&request))
        .await
        .map_err(|e| BrushError::Io(std::io::Error::new(
            std::io::ErrorKind::Other, 
            format!("Fetch error: {:?}", e)
        )))?;
    
    let resp: Response = resp_value.dyn_into().unwrap();
    let data = JsFuture::from(resp.array_buffer().unwrap())
        .await
        .map_err(|e| BrushError::Io(std::io::Error::new(
            std::io::ErrorKind::Other, 
            format!("Buffer error: {:?}", e)
        )))?;
        
    // Convert JS ArrayBuffer to Rust Vec<u8>
    let array = js_sys::Uint8Array::new(&data);
    let mut result = vec![0; array.length() as usize];
    array.copy_to(&mut result);
    
    Ok(result)
}

#[cfg(not(target_arch = "wasm32"))]
pub async fn load_resource(url: &str) -> Result<Vec<u8>, BrushError> {
    use tokio::fs::File;
    use tokio::io::AsyncReadExt;
    
    // For simplicity, treat URLs as local paths in native version
    let path = std::path::Path::new(url);
    
    let mut file = File::open(path).await?;
    let mut buffer = Vec::new();
    file.read_to_end(&mut buffer).await?;
    
    Ok(buffer)
}
```

